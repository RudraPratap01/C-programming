#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n,pos;
    scanf("%d",&n);
    int arr[n];
    for (int i=0;i<n;i++){
        scanf("%d ",&arr[i]);
    }
    int value;
    scanf("%d",&value);
    scanf("%d",&pos);
    for(int i=n;i>pos-1;i--){
        arr[i]=arr[i-1];
    }
    arr[0]=value;
    n++;
    for(int i=0;i<n;i++){
        printf("%d ",arr[i]);
    }
    return 0;
}
