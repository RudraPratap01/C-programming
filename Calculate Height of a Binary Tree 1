#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int height(int tree[], int n, int i) {
    if (i >= n || tree[i] == -1)
        return -1;
    int left = height(tree, n, 2*i + 1);
    int right = height(tree, n, 2*i + 2);
    return 1+(left > right ? left : right);
}
int main() {
    int n;
    scanf("%d", &n);
    int tree[n];
    for (int i = 0; i < n; i++){
        scanf("%d", &tree[i]);
    }
     printf("%d\n", height(tree, n, 0));
return 0;
}
