#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int n;
scanf("%d", &n);
int tree[n];
for (int i = 0; i < n; i++) {
    scanf("%d", &tree[i]);
}
int min = tree[0];
for (int i = 1; i < n; i++) {
    if (tree[i] < min && tree[i]>0) {
        min = tree[i];
    }
}
printf("%d\n", min); 
    return 0;
}
